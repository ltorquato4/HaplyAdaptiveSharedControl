{
  "name": "Research Seminar ROS 2",
  "build": {
    "context": "..",
    "dockerfile": "../docker/Dockerfile",
    "args": {
      "ROS_BASE_IMAGE": "osrf/ros:humble-desktop"
    }
  },
  "workspaceFolder": "/workspaces/research-seminar",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/research-seminar,type=bind,consistency=cached",
  "mounts": [
    "source=${devcontainerId}-build,target=/workspaces/research-seminar/build,type=volume",
    "source=${devcontainerId}-install,target=/workspaces/research-seminar/install,type=volume",
    "source=${devcontainerId}-log,target=/workspaces/research-seminar/log,type=volume",
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,readonly"
  ],
  "runArgs": [
    "--network=host",
    "--ipc=host"
  ],
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "QT_X11_NO_MITSHM": "1",
    "ROS_DISTRO": "humble",
    "ROS_DOMAIN_ID": "0",
    "WORKSPACE_DIR": "/workspaces/research-seminar",
    "SDL_AUDIODRIVER": "dummy",
    "AUDIODEV": "null",
    "PYGAME_HIDE_SUPPORT_PROMPT": "1"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.cpptools",
        "ms-iot.vscode-ros",
        "mhutchie.git-graph"
      ]
    }
  }
}
